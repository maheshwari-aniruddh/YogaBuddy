platform :ios, '18.0'

# Resolve Flutter helper paths
def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. Try re-running 'flutter pub get' in the project root."
  end
  File.foreach(generated_xcode_build_settings_path) do |line|
    match = line.match(/FLUTTER_ROOT\=(.*)/)
    return match[1].strip if match
  end
  raise "FLUTTER_ROOT not found. Run 'flutter pub get'."
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

target 'Runner' do
  use_frameworks! :linkage => :static
  use_modular_headers!

  # Force gRPC with the upstream fix (or newer)
  # If Firebase brings older gRPC, this bumps it to a compatible version.
  pod 'gRPC-Core', '>= 1.65.4'
  pod 'gRPC-C++',  '>= 1.65.4'

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  # Standard Flutter additional settings
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    # Ensure iOS 13+ to match modern Firebase/gRPC minimums
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
    end
  end

  # 1) Remove invalid '-G' compiler option injected by BoringSSL-GRPC on Xcode 16
  installer.pods_project.targets.each do |t|
    next unless t.name == 'BoringSSL-GRPC'
    t.source_build_phase.files.each do |file|
      next unless file.settings && file.settings['COMPILER_FLAGS']
      flags = file.settings['COMPILER_FLAGS'].split
      # Drop any -G… token (e.g., -GCC_WARN_INHIBIT_ALL_WARNINGS)
      flags.reject! { |f| f.start_with?('-G') }
      file.settings['COMPILER_FLAGS'] = flags.join(' ')
    end
  end

  # 2) Patch gRPC-Core header for Clang 19+/Xcode 16 parser strictness
  #    Replace: Traits::template CallSeqFactory(
  #    With:    Traits::template CallSeqFactory<>(
  hdr = File.join('Pods', 'gRPC-Core', 'src', 'core', 'lib', 'promise', 'detail', 'basic_seq.h')
  if File.exist?(hdr)
    contents = File.read(hdr)
    patched = contents.gsub(/Traits::\s*template\s+CallSeqFactory\(/, 'Traits::template CallSeqFactory<>(')
    if patched != contents
      File.open(hdr, 'w') { |f| f.write(patched) }
      puts 'Patched gRPC basic_seq.h to satisfy Clang CWG-96 parsing.'
    end
  end
end
