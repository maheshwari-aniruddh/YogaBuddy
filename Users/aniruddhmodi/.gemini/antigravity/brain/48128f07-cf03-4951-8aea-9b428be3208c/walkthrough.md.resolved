                  subtitle: l10n.dailyRemindersSubtitle,
                  value: _notificationsEnabled,
                  onChanged: (val) {
                    setState(() => _notificationsEnabled = val);
                    if (val) {
                      // Re-enable smart reminders
                      NotificationService().scheduleSmartReminders(
