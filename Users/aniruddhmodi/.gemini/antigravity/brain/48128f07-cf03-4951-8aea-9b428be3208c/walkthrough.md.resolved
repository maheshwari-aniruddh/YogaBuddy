                            ),
                            TextSpan(
                              text: ',\neffortlessly.',
                              style: TextStyle(
                                fontSize: 36,
                                fontWeight: FontWeight.w700,
                                color: Color(0xFF2D2326),
                                height: 1.2,
                                letterSpacing: -0.5,
                              ),
                            ),
                          ],
                        ),
                      ),
                      const SizedBox(height: 16),

                      // Subtitle
                      const Text(
                        'Your private audio journal with mood tracking.\nSecured with biometrics. Beautiful daily mindfulness.',
                        textAlign: TextAlign.center,
                        style: TextStyle(
                          fontSize: 15,
                          color: Color(0xFF8A7D80),
                          height: 1.5,
                          fontWeight: FontWeight.w400,
                        ),
                      ),
                      const SizedBox(height: 36),

                      // Error message
                      if (_error != null)
                        Padding(
                          padding: const EdgeInsets.only(bottom: 16),
                          child: Container(
                            padding: const EdgeInsets.symmetric(
                                horizontal: 16, vertical: 10),
                            decoration: BoxDecoration(
                              color: const Color(0xFFC48B8B)
                                  .withValues(alpha: 0.1),
                              borderRadius: BorderRadius.circular(12),
                            ),
                            child: Text(_error!,
                                style: const TextStyle(
                                    color: Color(0xFFC48B8B), fontSize: 13)),
                          ),
                        ),

                      // Sign in with Google — Primary CTA (dark pill)
                      if (_loading)
                        const SizedBox(
                          height: 54,
                          child: Center(
                            child: CircularProgressIndicator(
                              color: Color(0xFFC48B8B),
                              strokeWidth: 2.5,
                            ),
                          ),
                        )
                      else
                        SizedBox(
                          width: double.infinity,
                          height: 54,
                          child: ElevatedButton.icon(
                            style: ElevatedButton.styleFrom(
                              backgroundColor: const Color(0xFF2D2326),
                              foregroundColor: Colors.white,
                              elevation: 0,
                              shape: RoundedRectangleBorder(
                                borderRadius: BorderRadius.circular(27),
                              ),
                              shadowColor: const Color(0xFF2D2326)
