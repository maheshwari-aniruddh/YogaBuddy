                                  size: 18,
                                  color: Colors.white),
                            ),
                            label: Text(
                              l10n.signInGoogle,
                              style: const TextStyle(
                                fontSize: 15,
                                fontWeight: FontWeight.w600,
                                letterSpacing: 0.3,
                              ),
                            ),
                            onPressed: _signInWithGoogle,
                          ),
