                    subtitle: 'Prompts based on places you visit',
                    value: _locationSuggestionsEnabled,
                    onChanged: (val) async {
                      if (val) {
                        // Request location permission
                        final granted =
                            await LocationService().requestPermission();
                        if (!granted) {
                          if (mounted) {
                            ScaffoldMessenger.of(context).showSnackBar(
                              const SnackBar(
                                content: Text(
