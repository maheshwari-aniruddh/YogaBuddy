  void _showDemoLoginDialog() {
    final userController = TextEditingController();
    final passController = TextEditingController();

    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        backgroundColor: const Color(0xFFFDFBF7),
        shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(20)),
        title: const Text('Demo Login',
            style: TextStyle(
              color: Color(0xFF2D2326),
              fontWeight: FontWeight.w700,
            )),
        content: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            TextField(
              controller: userController,
              decoration: InputDecoration(
                  labelText: 'Username',
                  labelStyle: const TextStyle(color: Color(0xFF8A7D80)),
                  border: OutlineInputBorder(
                      borderRadius: BorderRadius.circular(12)),
                  focusedBorder: OutlineInputBorder(
                    borderRadius: BorderRadius.circular(12),
                    borderSide: const BorderSide(color: Color(0xFFC48B8B)),
                  )),
            ),
            const SizedBox(height: 12),
            TextField(
              controller: passController,
              decoration: InputDecoration(
                  labelText: 'Password',
                  labelStyle: const TextStyle(color: Color(0xFF8A7D80)),
                  border: OutlineInputBorder(
                      borderRadius: BorderRadius.circular(12)),
                  focusedBorder: OutlineInputBorder(
                    borderRadius: BorderRadius.circular(12),
                    borderSide: const BorderSide(color: Color(0xFFC48B8B)),
                  )),
              obscureText: true,
            ),
          ],
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(context),
            child: const Text('Cancel',
                style: TextStyle(color: Color(0xFF8A7D80))),
          ),
          ElevatedButton(
            style: ElevatedButton.styleFrom(
              backgroundColor: const Color(0xFF2D2326),
              foregroundColor: Colors.white,
              shape: RoundedRectangleBorder(
                  borderRadius: BorderRadius.circular(12)),
            ),
            onPressed: () async {
              if (userController.text == 'user01' &&
                  passController.text == 'appleBest') {
                Navigator.pop(context);
                setState(() => _loading = true);
                try {
                  if (mounted) {
                    await Provider.of<Store>(context, listen: false)
                        .initialize(null);
                    Navigator.of(context).pushReplacement(
                      MaterialPageRoute(
                          builder: (_) => const MainScreen(user: null)),
                    );
                  }
                } finally {
                  if (mounted) setState(() => _loading = false);
                }
              } else {
                ScaffoldMessenger.of(context).showSnackBar(
                  const SnackBar(
                      content: Text('Invalid credentials'),
                      backgroundColor: Color(0xFFC48B8B)),
                );
              }
            },
            child: const Text('Login'),
          ),
        ],
      ),
    );
  }
}
